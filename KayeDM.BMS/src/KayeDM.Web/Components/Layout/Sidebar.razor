@implements IDisposable
@inject NavigationManager Nav

<aside class="sidebar-shell">
    <div class="sidebar-header">
        <a href="/" class="sidebar-brand">
            <img src="img/kaye-dm-logo-3d-64.png" alt="Kaye &amp; DM" width="40" height="40" />
            <span class="sidebar-brand__text">Kaye &amp; DM</span>
        </a>
        <button type="button" class="sidebar-toggle" aria-label="Toggle navigation"
                aria-expanded="@_mobileOpen.ToString().ToLowerInvariant()" @onclick="ToggleMobile">
            <span></span><span></span><span></span>
        </button>
    </div>

    <nav class="sidebar-nav @(_mobileOpen ? "sidebar-nav--open" : "")">
        <AuthorizeView Roles="Owner">
            <div class="nav-item">
                <NavLink class="nav-link" href="dashboard" Match="NavLinkMatch.All">Dashboard</NavLink>
            </div>
        </AuthorizeView>

        <NavGroup Label="Sales" RoutePrefixes="@(new[] { "pos", "closing" })">
            <div class="nav-item">
                <NavLink class="nav-link" href="pos" Match="NavLinkMatch.All">POS</NavLink>
            </div>
            <AuthorizeView Roles="Owner">
                <div class="nav-item">
                    <NavLink class="nav-link" href="closing" Match="NavLinkMatch.All">Daily Closing</NavLink>
                </div>
            </AuthorizeView>
        </NavGroup>

        <NavGroup Label="Buses" RoutePrefixes="@(new[] { "buses/arrivals", "buses/companies" })">
            <div class="nav-item">
                <NavLink class="nav-link" href="buses/arrivals" Match="NavLinkMatch.All">Arrivals</NavLink>
            </div>
            <AuthorizeView Roles="Owner">
                <div class="nav-item">
                    <NavLink class="nav-link" href="buses/companies" Match="NavLinkMatch.All">Companies</NavLink>
                </div>
            </AuthorizeView>
        </NavGroup>

        <NavGroup Label="Inventory" RoutePrefixes="@(new[] { "inventory/production", "inventory/waste" })">
            <div class="nav-item">
                <NavLink class="nav-link" href="inventory/production" Match="NavLinkMatch.All">Production</NavLink>
            </div>
            <div class="nav-item">
                <NavLink class="nav-link" href="inventory/waste" Match="NavLinkMatch.All">Waste</NavLink>
            </div>
        </NavGroup>

        <AuthorizeView Roles="Owner">
            <NavGroup Label="Expenses" RoutePrefixes="@(new[] { "expenses", "expenses/categories" })">
                <div class="nav-item">
                    <NavLink class="nav-link" href="expenses" Match="NavLinkMatch.All">Entry</NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="expenses/categories" Match="NavLinkMatch.All">Categories</NavLink>
                </div>
            </NavGroup>
        </AuthorizeView>

        <AuthorizeView Roles="Owner">
            <NavGroup Label="Reports" RoutePrefixes="@(new[] { "reports", "buses/report", "inventory/variance", "expenses/report", "closing/history" })">
                <div class="nav-item">
                    <NavLink class="nav-link" href="reports" Match="NavLinkMatch.All">Overview</NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="buses/report" Match="NavLinkMatch.All">Crew Meals</NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="inventory/variance" Match="NavLinkMatch.All">Variance</NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="expenses/report" Match="NavLinkMatch.All">Expenses</NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="closing/history" Match="NavLinkMatch.All">Daily Closings</NavLink>
                </div>
            </NavGroup>
        </AuthorizeView>

        <AuthorizeView Roles="Owner">
            <div class="nav-item">
                <NavLink class="nav-link" href="menu" Match="NavLinkMatch.All">Menu</NavLink>
            </div>
        </AuthorizeView>
    </nav>

    <div class="sidebar-footer">
        <AuthorizeView>
            <Authorized>
                <div class="user-chip">
                    <span class="user-chip__name">@context.User.Identity?.Name</span>
                    <span class="role-badge @(context.User.IsInRole("Owner") ? "role-badge--owner" : "role-badge--cashier")">
                        @(context.User.IsInRole("Owner") ? "Owner" : "Cashier")
                    </span>
                </div>
                <form method="post" action="account/logout">
                    <AntiforgeryToken />
                    <button type="submit" class="sidebar-logout">Log Out</button>
                </form>
            </Authorized>
        </AuthorizeView>
    </div>
</aside>

@code {
    private bool _mobileOpen;

    protected override void OnInitialized() => Nav.LocationChanged += OnLocationChanged;

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _mobileOpen = false;
        InvokeAsync(StateHasChanged);
    }

    private void ToggleMobile() => _mobileOpen = !_mobileOpen;

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
