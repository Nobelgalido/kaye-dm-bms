@page "/buses/report"
@attribute [Authorize(Roles = "Owner")]
@using Microsoft.AspNetCore.Authorization
@using KayeDM.Application.Buses
@using KayeDM.Domain.Exceptions
@inject IBusService BusService

<PageTitle>Crew Meal Report — Kaye & DM BMS</PageTitle>

<div class="report-page">
    <PageHeader Title="Monthly Crew Meal Report" />

    <ReportFilterBar OnRun="LoadReportAsync" IsLoading="_isLoading">
        <div class="field @(_error is not null ? "field--invalid" : null)">
            <label for="crew-report-company">Company</label>
            <select id="crew-report-company" @bind="_selectedCompanyId">
                <option value="0">-- select --</option>
                @foreach (var company in _companies)
                {
                    <option value="@company.Id">@company.Name</option>
                }
            </select>
        </div>
        <div class="field">
            <label for="crew-report-month">Month (YYYY-MM)</label>
            <input id="crew-report-month" type="text" placeholder="2026-07" @bind="_monthInput" />
            @if (_error is not null)
            {
                <span class="field__error">@_error</span>
            }
        </div>
    </ReportFilterBar>

    @if (_report is null)
    {
        <ReportEmptyState Message="Choose a company and month, then run the report to see crew meal credits.">
            <Glyph>
                <Icon Name="reports-crew-meals" Size="40" />
            </Glyph>
        </ReportEmptyState>
    }
    else
    {
        <p class="report-page__subtitle">@_report.CompanyName — @_report.Year-@_report.Month.ToString("D2")</p>
        <div class="report-summary">
            <KpiCard Label="Trips" NumericValue="_report.TotalTrips" Decimals="0" Animate="_resultsVersion == 1" />
            <KpiCard Label="Driver Meals" NumericValue="_report.DriverMealsTotal" Decimals="0" />
            <KpiCard Label="Conductor Meals" NumericValue="_report.ConductorMealsTotal" Decimals="0" />
            <KpiCard Label="Assistant Meals" NumericValue="_report.AssistantMealsTotal" Decimals="0" />
            <KpiCard Label="Total Meals" NumericValue="_report.TotalMeals" Decimals="0" Highlight="true" Animate="_resultsVersion == 1" />
        </div>

        <ReportTableFrame RefreshKey="_resultsVersion">
            @if (_report.Trips.Count == 0)
            {
                <ReportEmptyState Message="No trips recorded for this company in this month.">
                    <Glyph>
                        <Icon Name="reports-crew-meals" Size="40" />
                    </Glyph>
                </ReportEmptyState>
            }
            else
            {
                <table class="report-table">
                    <thead>
                        <tr>
                            <th>Arrived</th>
                            <th>Bus No.</th>
                            <th>Route</th>
                            <th class="report-table__money-head">Driver</th>
                            <th class="report-table__money-head">Conductor</th>
                            <th class="report-table__money-head">Assistant</th>
                            <th class="report-table__money-head">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _report.Trips)
                        {
                            <tr>
                                <td>@row.ArrivedAt.ToString("MMM d, h:mm tt")</td>
                                <td>@row.BusNumber</td>
                                <td>@row.Route</td>
                                <td class="report-table__money">@row.DriverCredits</td>
                                <td class="report-table__money">@row.ConductorCredits</td>
                                <td class="report-table__money">@row.AssistantCredits</td>
                                <td class="report-table__money">@row.TotalCredits</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="3">Totals (@_report.TotalTrips trips)</th>
                            <th class="report-table__money-head">@_report.DriverMealsTotal</th>
                            <th class="report-table__money-head">@_report.ConductorMealsTotal</th>
                            <th class="report-table__money-head">@_report.AssistantMealsTotal</th>
                            <th class="report-table__money-head">@_report.TotalMeals</th>
                        </tr>
                    </tfoot>
                </table>
            }
        </ReportTableFrame>
    }
</div>

@code {
    private List<BusCompanyDto> _companies = new();
    private int _selectedCompanyId;
    private string _monthInput = DateTime.Now.ToString("yyyy-MM");
    private CrewMealReportResult? _report;
    private string? _error;
    private bool _isLoading;
    private int _resultsVersion;

    protected override async Task OnInitializedAsync()
    {
        _companies = await BusService.GetCompaniesAsync(includeInactive: true);
    }

    private async Task LoadReportAsync()
    {
        _error = null;

        if (_selectedCompanyId <= 0)
        {
            _error = "Select a bus company.";
            _report = null;
            return;
        }

        if (!DateTime.TryParse(_monthInput + "-01", out var parsed))
        {
            _error = "Select a valid month.";
            _report = null;
            return;
        }

        _isLoading = true;
        try
        {
            _report = await BusService.GetMonthlyReportAsync(_selectedCompanyId, parsed.Year, parsed.Month);
            _resultsVersion++;
        }
        catch (DomainException ex)
        {
            _error = ex.Message;
            _report = null;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
