@page "/pos"
@attribute [Authorize(Roles = "Owner,Cashier")]
@using Microsoft.AspNetCore.Authorization
@using KayeDM.Application.Buses
@using KayeDM.Application.Inventory
@using KayeDM.Application.Menu
@using KayeDM.Application.Orders
@using KayeDM.Domain.Enums
@using KayeDM.Domain.Exceptions
@inject IMenuItemService MenuItemService
@inject IOrderService OrderService
@inject IBusService BusService
@inject IInventoryService InventoryService

<PageTitle>POS — Kaye & DM BMS</PageTitle>

<div class="pos-page">
    <div class="pos-menu">
        <div class="pos-tabs">
            @foreach (var category in Enum.GetValues<MenuCategory>())
            {
                <button type="button" class="pos-tab @(category == _activeCategory ? "pos-tab--active" : "")"
                        @onclick="() => _activeCategory = category">
                    @category
                </button>
            }
        </div>
        <div class="pos-grid">
            @foreach (var item in _menuItems.Where(m => m.Category == _activeCategory))
            {
                var availability = _availability.FirstOrDefault(a => a.MenuItemId == item.Id);
                <button type="button" class="pos-item pos-item--@item.Category.ToString().ToLowerInvariant()" @onclick="() => AddLine(item)">
                    @if (availability is not null && availability.HasBatchToday && availability.AvailableServings <= 5)
                    {
                        <span class="pos-item__pill @(availability.AvailableServings <= 0 ? "pos-item__pill--out" : "pos-item__pill--low")">
                            @(availability.AvailableServings <= 0 ? "0 left" : $"{availability.AvailableServings} left")
                        </span>
                    }
                    <span class="pos-item__name">@item.Name</span>
                    <span class="pos-item__price">@FormatPeso(item.Price)</span>
                    @if (availability is not null && !availability.HasBatchToday)
                    {
                        <span class="pos-item__nobatch">no batch</span>
                    }
                </button>
            }
        </div>
    </div>

    <div class="pos-side">
        <div class="pos-ticket @(_isCrewMealMode ? "pos-ticket--crew" : "")">
            @if (_isCrewMealMode)
            {
                <div class="pos-ticket__banner">CREW MEAL@(_selectedTripLabel is not null ? $" — {_selectedTripLabel}" : "")</div>
            }
            <div class="pos-ticket__header">Ticket</div>
            <div class="pos-ticket__lines">
                @if (_ticket.Count == 0)
                {
                    <p class="pos-ticket__empty">No items yet — tap a dish to start the order.</p>
                }
                else
                {
                    @foreach (var line in _ticket)
                    {
                        <div class="pos-ticket__line">
                            <span class="pos-ticket__line-name">@line.MenuItem.Name</span>
                            <div class="pos-stepper">
                                <button type="button" class="pos-stepper__btn" @onclick="() => ChangeQty(line, -1)" aria-label="Decrease quantity">−</button>
                                <span class="pos-stepper__value">@line.Quantity</span>
                                <button type="button" class="pos-stepper__btn" @onclick="() => ChangeQty(line, 1)" aria-label="Increase quantity">+</button>
                            </div>
                            <span class="pos-ticket__line-total">@FormatPeso(line.MenuItem.Price * line.Quantity)</span>
                            <button type="button" class="pos-ticket__remove" @onclick="() => RemoveLine(line)" aria-label="Remove @line.MenuItem.Name">✕</button>
                        </div>
                    }
                }
            </div>
            <div class="pos-ticket__footer">
                <span>Total</span>
                <strong>@FormatPeso(Total)</strong>
            </div>
        </div>

        <div class="pos-payment">
            <div class="field">
                <label for="pos-bus-select">Assign to bus (optional)</label>
                <div class="pos-payment__bus-row">
                    <select id="pos-bus-select" @bind="_selectedBusTripId">
                        <option value="">-- none --</option>
                        @foreach (var trip in _recentTrips)
                        {
                            <option value="@trip.Id">@trip.BusCompanyName · @trip.BusNumber</option>
                        }
                    </select>
                    <button type="button" class="pos-payment__refresh" @onclick="RefreshTripsAsync">Refresh</button>
                </div>
            </div>

            <label class="pos-checkbox">
                <input type="checkbox" @bind="_isCrewMealMode" />
                Crew Meal Mode (free meal for bus crew)
            </label>

            @if (_isCrewMealMode)
            {
                <div class="field">
                    <label>Crew Role</label>
                    <div class="pos-segmented">
                        @foreach (var role in Enum.GetValues<CrewRole>())
                        {
                            <button type="button" class="pos-segmented__btn @(role == _crewRole ? "pos-segmented__btn--active" : "")"
                                    @onclick="() => _crewRole = role">@role</button>
                        }
                    </div>
                </div>
            }

            @if (!_isCrewMealMode)
            {
                <div class="pos-segmented">
                    <button type="button" class="pos-segmented__btn @(_paymentMethod == PaymentMethod.Cash ? "pos-segmented__btn--active" : "")"
                            @onclick="() => _paymentMethod = PaymentMethod.Cash">Cash</button>
                    <button type="button" class="pos-segmented__btn @(_paymentMethod == PaymentMethod.GCash ? "pos-segmented__btn--active" : "")"
                            @onclick="() => _paymentMethod = PaymentMethod.GCash">GCash</button>
                </div>

                @if (_paymentMethod == PaymentMethod.Cash)
                {
                    <div class="pos-quick-amounts">
                        @foreach (var amount in new decimal[] { 100, 200, 500, 1000 })
                        {
                            <button type="button" class="pos-quick-amounts__btn" @onclick="() => Tendered = amount">@FormatPeso(amount)</button>
                        }
                    </div>
                    <div class="field">
                        <label for="pos-tendered">Tendered</label>
                        <input id="pos-tendered" type="number" @bind="Tendered" step="0.01" />
                    </div>
                    <div class="pos-change @(Change >= 0 ? "pos-change--positive" : "pos-change--negative")">
                        Change: @FormatPeso(Change)
                    </div>
                }
                else
                {
                    <div class="pos-change">Total to pay via GCash: @FormatPeso(Total)</div>
                }
            }
            else
            {
                <div class="pos-change pos-change--positive">Crew meal — total: @FormatPeso(0m) (free)</div>
            }

            <button type="button" class="pos-payment__complete" disabled="@(!CanComplete || _isCompleting)" @onclick="CompleteAsync">
                @if (_isCompleting)
                {
                    <span class="pos-payment__spinner" aria-hidden="true"></span>
                }
                Complete
            </button>
            <button type="button" class="pos-payment__clear" @onclick="ClearTicket">Clear</button>

            @if (_lastOrderNumber is not null)
            {
                <div class="alert alert-success">Order @_lastOrderNumber saved. Change: @FormatPeso(_lastChange)</div>
            }
            @if (_oversoldWarning is not null)
            {
                <div class="alert alert-warning pos-oversold">
                    @_oversoldWarning
                    <button type="button" class="pos-oversold__action" @onclick="ConfirmOversoldAndCompleteAsync">Confirm &amp; Sell Anyway</button>
                </div>
            }
            @if (_error is not null)
            {
                <div class="alert alert-danger">@_error</div>
            }
        </div>
    </div>
</div>

@code {
    private List<MenuItemDto> _menuItems = new();
    private MenuCategory _activeCategory = MenuCategory.Ulam;
    private List<TicketLine> _ticket = new();
    private PaymentMethod _paymentMethod = PaymentMethod.Cash;
    private decimal Tendered { get; set; }
    private string? _lastOrderNumber;
    private decimal _lastChange;
    private string? _error;
    private string? _oversoldWarning;
    private bool _oversoldConfirmed;
    private bool _isCompleting;

    private List<BusTripDto> _recentTrips = new();
    private int? _selectedBusTripId;
    private bool _isCrewMealMode;
    private CrewRole _crewRole = CrewRole.Driver;
    private List<MenuItemAvailabilityDto> _availability = new();

    private decimal Total => _ticket.Sum(l => l.MenuItem.Price * l.Quantity);
    private decimal Change => Tendered - Total;

    private string? _selectedTripLabel => _recentTrips
        .FirstOrDefault(t => t.Id == _selectedBusTripId) is { } trip
            ? $"{trip.BusCompanyName} · {trip.BusNumber}"
            : null;

    private bool CanComplete => _ticket.Count > 0 &&
        (_isCrewMealMode
            ? _selectedBusTripId is not null
            : (_paymentMethod == PaymentMethod.GCash || Tendered >= Total));

    protected override async Task OnInitializedAsync()
    {
        _menuItems = await MenuItemService.GetAllAsync();
        _availability = await InventoryService.GetTodaysAvailabilityAsync();
        await RefreshTripsAsync();
    }

    private async Task RefreshTripsAsync()
    {
        _recentTrips = await BusService.GetRecentArrivalsAsync(TimeSpan.FromMinutes(45));
    }

    private void AddLine(MenuItemDto item)
    {
        var existing = _ticket.FirstOrDefault(l => l.MenuItem.Id == item.Id);
        if (existing is not null)
        {
            existing.Quantity++;
        }
        else
        {
            _ticket.Add(new TicketLine { MenuItem = item, Quantity = 1 });
        }
    }

    private void ChangeQty(TicketLine line, int delta)
    {
        line.Quantity += delta;
        if (line.Quantity <= 0)
        {
            _ticket.Remove(line);
        }
    }

    private void RemoveLine(TicketLine line) => _ticket.Remove(line);

    private void ClearTicket()
    {
        _ticket.Clear();
        Tendered = 0;
        _lastOrderNumber = null;
        _error = null;
        _oversoldWarning = null;
        _oversoldConfirmed = false;
        _isCrewMealMode = false;
        _selectedBusTripId = null;
    }

    private static string FormatPeso(decimal amount) => string.Format("₱{0:N2}", amount);

    private async Task CompleteAsync()
    {
        _error = null;
        _isCompleting = true;
        try
        {
            OrderResult result;
            if (_isCrewMealMode)
            {
                if (_selectedBusTripId is null)
                {
                    _error = "Select a bus trip for the crew meal.";
                    return;
                }

                var crewRequest = new CreateCrewMealOrderRequest(
                    _ticket.Select(l => new OrderLineRequest(l.MenuItem.Id, l.Quantity)).ToList(),
                    _selectedBusTripId.Value,
                    _crewRole,
                    CashierId: null);

                result = await OrderService.CreateCrewMealOrderAsync(crewRequest);
            }
            else
            {
                var request = new CreateOrderRequest(
                    _ticket.Select(l => new OrderLineRequest(l.MenuItem.Id, l.Quantity)).ToList(),
                    _paymentMethod,
                    Tendered,
                    CashierId: null,
                    BusTripId: _selectedBusTripId,
                    OversoldOverride: _oversoldConfirmed);

                result = await OrderService.CreateOrderAsync(request);
            }

            _lastOrderNumber = result.OrderNumber;
            _lastChange = result.ChangeGiven;
            _ticket.Clear();
            Tendered = 0;
            _isCrewMealMode = false;
            _selectedBusTripId = null;
            _oversoldConfirmed = false;
            _oversoldWarning = null;
            await RefreshTripsAsync();
            _availability = await InventoryService.GetTodaysAvailabilityAsync();
        }
        catch (OversoldException ex)
        {
            _oversoldWarning = ex.Message;
        }
        catch (DomainException ex)
        {
            _error = ex.Message;
        }
        catch (Exception)
        {
            _error = "Something went wrong completing this order. Please try again.";
        }
        finally
        {
            _isCompleting = false;
        }
    }

    private async Task ConfirmOversoldAndCompleteAsync()
    {
        _oversoldConfirmed = true;
        await CompleteAsync();
    }

    private class TicketLine
    {
        public MenuItemDto MenuItem { get; set; } = null!;
        public int Quantity { get; set; }
    }
}
