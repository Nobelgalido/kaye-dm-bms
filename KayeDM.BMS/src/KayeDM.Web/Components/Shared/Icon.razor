<svg class="icon" viewBox="0 0 24 24" width="@Size" height="@Size" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    @switch (Name)
    {
        case "dashboard":
            <path d="M4 16a8 8 0 0 1 16 0" />
            <path d="M12 16l4.5-5.5" />
            <circle cx="12" cy="16" r="1.2" />
            break;
        case "pos":
            <path d="M6 8h12l-1 11a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L6 8Z" />
            <path d="M9 8V6a3 3 0 0 1 6 0v2" />
            break;
        case "closing":
            <rect x="5" y="11" width="14" height="9" rx="2" />
            <path d="M8 11V7a4 4 0 0 1 8 0v4" />
            break;
        case "bus":
        case "reports-crew-meals":
            <rect x="3" y="6" width="18" height="11" rx="2" />
            <path d="M3 12h18" />
            <circle cx="7.5" cy="19" r="1.5" />
            <circle cx="16.5" cy="19" r="1.5" />
            break;
        case "building":
            <path d="M5 21V7l7-4 7 4v14" />
            <path d="M9 21v-6h6v6" />
            break;
        case "trays":
            <ellipse cx="12" cy="7" rx="7" ry="2.2" />
            <path d="M5 7v5c0 1.2 3.1 2.2 7 2.2s7-1 7-2.2V7" />
            <path d="M5 12v5c0 1.2 3.1 2.2 7 2.2s7-1 7-2.2v-5" />
            break;
        case "waste":
            <path d="M4 7h16" />
            <path d="M9 7V4h6v3" />
            <path d="M6 7l1 13a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2l1-13" />
            break;
        case "wallet":
            <path d="M3 7a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v1h1a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7Z" />
            <path d="M16 12h3" />
            break;
        case "tag":
            <path d="M11 3h6a2 2 0 0 1 2 2v6l-9 9-8-8 9-9Z" />
            <circle cx="15.5" cy="8.5" r="1.25" />
            break;
        case "reports-overview":
            <rect x="4" y="4" width="7" height="7" rx="1.5" />
            <rect x="13" y="4" width="7" height="7" rx="1.5" />
            <rect x="4" y="13" width="7" height="7" rx="1.5" />
            <rect x="13" y="13" width="7" height="7" rx="1.5" />
            break;
        case "reports-variance":
            <path d="M2 20h20" />
            <path d="M5 20v-9" />
            <path d="M12 20V5" />
            <path d="M19 20v-6" />
            break;
        case "reports-expenses":
            <path d="M6 3h12v18l-3-2-3 2-3-2-3 2Z" />
            <path d="M9 8h6" />
            <path d="M9 12h6" />
            break;
        case "reports-closing-history":
            <rect x="3" y="5" width="18" height="16" rx="2" />
            <path d="M3 9h18" />
            <path d="M8 3v4" />
            <path d="M16 3v4" />
            <path d="M8.5 14.5l2 2 4-4.5" />
            break;
        case "menu":
            <path d="M7 3v7a2 2 0 1 0 4 0V3" />
            <path d="M9 10v11" />
            <path d="M16 3c-1.5 1-2 3-2 5s.8 3 2 3 2-1 2-3-.5-4-2-5Z" />
            <path d="M16 11v10" />
            break;
        case "logout":
            <path d="M9 21H6a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3" />
            <path d="M16 17l5-5-5-5" />
            <path d="M21 12H9" />
            break;
    }
</svg>

@code {
    [Parameter, EditorRequired]
    public string Name { get; set; } = "";

    [Parameter]
    public int Size { get; set; } = 20;
}
