<div class="report-filters">
    <div class="report-filters__fields">
        @ChildContent
    </div>
    <button type="button" class="report-filters__run" @onclick="OnRun" disabled="@IsLoading">
        @if (IsLoading)
        {
            <span class="report-filters__spinner" aria-hidden="true"></span>
        }
        @RunLabel
    </button>
</div>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public EventCallback OnRun { get; set; }

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public string RunLabel { get; set; } = "Run Report";
}
