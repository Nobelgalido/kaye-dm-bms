@inject IJSRuntime JS

<div class="kpi-card">
    <span class="kpi-card__label">@Label</span>
    @if (NumericValue.HasValue)
    {
        <strong class="kpi-card__value" id="@_elementId">@FormatNumeric(NumericValue.Value)</strong>
    }
    else
    {
        <strong class="kpi-card__value kpi-card__value--text">@DisplayText</strong>
    }
    @if (!string.IsNullOrEmpty(SubText))
    {
        <span class="kpi-card__sub">@SubText</span>
    }
</div>

@code {
    private readonly string _elementId = $"kpi-{Guid.NewGuid():N}";

    [Parameter, EditorRequired]
    public string Label { get; set; } = "";

    [Parameter]
    public decimal? NumericValue { get; set; }

    [Parameter]
    public string? DisplayText { get; set; }

    [Parameter]
    public string? SubText { get; set; }

    [Parameter]
    public string Prefix { get; set; } = "";

    [Parameter]
    public int Decimals { get; set; } = 2;

    // Set true only for the very first load of the page's data — the count-up
    // is a one-shot moment, never replayed on filter refresh.
    [Parameter]
    public bool Animate { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Animate && NumericValue.HasValue)
        {
            await JS.InvokeVoidAsync("kayeDm.countUp", _elementId, (double)NumericValue.Value, Prefix, Decimals, 600);
        }
    }

    private string FormatNumeric(decimal value) =>
        $"{Prefix}{value.ToString(Decimals == 0 ? "N0" : "N2", System.Globalization.CultureInfo.InvariantCulture)}";
}
